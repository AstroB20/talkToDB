# ── TalktoDB — Streamlit UI ───────────────────────────────────────────────
# Public-facing web chat interface. Talks to the FastAPI backend over HTTP.
# This image is intentionally lightweight — no DB drivers or LangChain needed.
#
# Build:
#   docker build -f Dockerfile.ui -t talktodb-ui .
#
# Run locally:
#   docker run --env-file .env -p 8501:8501 talktodb-ui
#
# Cloud Run note:
#   Cloud Run injects $PORT. Streamlit must bind on that port.
#   Set API_URL to the internal Cloud Run URL of the API service.
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# ── Install only UI dependencies (keeps image small) ──────────────────────
RUN pip install --no-cache-dir \
    streamlit>=1.40.0 \
    plotly>=5.20.0 \
    pandas>=2.2.0 \
    httpx>=0.27.0

# ── Copy only the UI source ───────────────────────────────────────────────
COPY ui/ ./ui/

# ── Streamlit config — disable telemetry, enable CORS for Cloud Run ────────
RUN mkdir -p /app/.streamlit && \
    printf '[server]\nheadless = true\nenableCORS = false\nenableXsrfProtection = false\n\n[browser]\ngatherUsageStats = false\n' \
    > /app/.streamlit/config.toml

# ── Create non-root user ──────────────────────────────────────────────────
RUN adduser --disabled-password --gecos "" --uid 1001 appuser \
    && chown -R appuser:appuser /app

USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:${PORT:-8501}/_stcore/health')" || exit 1

# Bind Streamlit on $PORT (Cloud Run) or 8501 (local)
CMD ["sh", "-c", "streamlit run ui/app.py --server.port ${PORT:-8501} --server.address 0.0.0.0"]
