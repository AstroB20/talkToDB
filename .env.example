# Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Agent role: controls which CRUD operations are permitted
# Options: admin | editor | analyst  (see config/access_control.yaml)
AGENT_ROLE=admin

# FastAPI backend address (used by the Streamlit UI)
API_URL=http://localhost:8000
